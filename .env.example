# API del modulo de Clientes
CLIENTES_API_URL=http://35.239.247.220:8001
CLIENTES_API_ENDPOINT=/clientes

# API del modulo de ventas/pagos
VENTAS_API_URL=http://34.176.33.216:8000
VENTAS_API_ENDPOINT=/payments/view-payments
VENTAS_API_PAGINATED=false

# Filtro por defecto. Usa PAGADO para contar ventas reales.
# Otros estados posibles segun el modulo de pagos: REEMBOLSO.
VENTAS_API_DEFAULT_STATUS=PAGADO
VENTAS_API_DAY=false
VENTAS_API_WEEK=false

# API de alquileres del modulo de ventas/pagos.
# Se usa para convertir rental_id en customer_id cuando pagos no trae customer_id.
RENTALS_API_URL=http://34.176.33.216:8000
RENTALS_API_ENDPOINT=/api/v1/rentals

# Paginacion y timeout para consumir APIs.
API_PAGE_SIZE=100
API_TIMEOUT=15

# Campos esperados en la respuesta de la API de ventas/pagos.
VENTA_CLIENTE_ID_FIELD=customer_id
VENTA_RENTAL_ID_FIELD=rental_id
VENTA_TOTAL_FIELD=amount
VENTA_FECHA_FIELD=payment_date
VENTA_STATUS_FIELD=status
VENTA_STATUS_PERMITIDO=PAGADO
RENTAL_CLIENTE_ID_FIELD=customer_id
